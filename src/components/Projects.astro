---
import GitHub from "./icons/GitHub.astro"
import LinkButton from "./LinkButton.astro"

const TAG_STYLES: Record<string, string> = {
  HTML: "bg-[#e34f26] text-white",
  CSS: "bg-[#1572b6] text-white",
  JavaScript: "bg-[#f7df1e] text-gray-900",
  PHP: "bg-[#777bb4] text-white",
  "Node.js": "bg-[#339933] text-white",
  "Express.js": "bg-[#000000] text-white",
}

const PROJECTS = [
  {
    title: "Computer Equipment Inventory Management System",
    description:
      "Corporate web application designed to register, manage, and maintain traceability of IT equipment. Includes detailed information records, automatic ticket generation, movement history, advanced filtering, and access control through IWA.",
    github: "https://github.com/JossMunguia03/Inventario_Computadoras",
    images: [
      "/projects/GestionCompus1.jpg",
      "/projects/GestionCompus2.jpg",
      "/projects/GestionCompus3.jpg",
      "/projects/GestionCompus4.jpg",
    ],
    tags: ["HTML", "CSS", "JavaScript", "PHP"],
  },
  {
    title: "Visitor Control and Registration System",
    description:
      "Web application for visitor registration, image capture, badge control, and entry/exit logging.",
    github: "https://github.com/JossMunguia03/Control_Visitas",
    images: ["/projects/Visitas1.jpg"],
    tags: ["HTML", "CSS", "JavaScript", "PHP"],
  },
  {
    title: "Tooling and Process Change Management System",
    description:
      "Web application designed to register, monitor, and approve changes in manufacturing and molding processes through a multi-department approval workflow with full traceability.",
    github: "https://github.com/JossMunguia03/TPC",
    images: [
      "/projects/ToolingProcess1.jpg",
      "/projects/ToolingProcess2.jpg",
    ],
    tags: ["HTML", "CSS", "JavaScript", "PHP"],
  },
  {
    title: "PerfuMetric",
    description:
      "Web project aimed at managing and analyzing perfumes, organizing their main information in a database or system to facilitate queries, inventory and product control.",
    github: "https://github.com/JossMunguia03/Public_Perfumetric",
    images: [
      "/projects/Perfumetric1.jpg",
      "/projects/Perfumetric2.jpg",
      "/projects/Perfumetric3.jpg",
      "/projects/Perfumetric4.jpg",
    ],
    tags: ["HTML", "CSS", "JavaScript", "PHP"],
  },
  {
    title: "GratiDay",
    description:
      "Full web platform designed to manage gratitude quotes, categories, and users, developed with a REST API architecture on the backend and Micro-Frontends (Web Components) on the frontend.",
    github: "https://github.com/JossMunguia03/CuartoAvance",
    images: [
      "/projects/Gratiday1.jpg",
      "/projects/Gratiday2.jpg",
      "/projects/Gratiday3.jpg",
      "/projects/Gratiday4.jpg",
    ],
    tags: ["HTML", "CSS", "JavaScript", "Node.js", "Express.js"],
  },
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ images, title, description, tags, github }, projectIndex) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div
            class="project-carousel relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50"
            data-project-index={projectIndex}
          >
            <div class="project-carousel-track relative w-full h-56 sm:h-72 md:h-80">
              {
                images.map((image, imageIndex) => (
                  <button
                    type="button"
                    class={`project-carousel-slide project-image-trigger ${imageIndex === 0 ? "is-active" : ""}`}
                    data-project-index={projectIndex}
                    data-image-index={imageIndex}
                    data-image-src={image}
                    data-image-alt={`${title} screenshot ${imageIndex + 1}`}
                    aria-label={`View ${title} screenshot ${imageIndex + 1} in full size`}
                  >
                    <img
                      alt={`${title} screenshot ${imageIndex + 1}`}
                      class="object-cover object-top w-full h-full transition duration-500 md:scale-110 md:group-hover:scale-105 pointer-events-none"
                      loading="lazy"
                      src={image}
                    />
                  </button>
                ))
              }
            </div>

            {
              images.length > 1 && (
                <>
                  <button
                    type="button"
                    class="project-carousel-btn project-carousel-btn--prev"
                    aria-label={`Previous image for ${title}`}
                    data-direction="prev"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M15 18l-6-6 6-6"></path>
                    </svg>
                  </button>
                  <button
                    type="button"
                    class="project-carousel-btn project-carousel-btn--next"
                    aria-label={`Next image for ${title}`}
                    data-direction="next"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9 18l6-6-6-6"></path>
                    </svg>
                  </button>
                  <div class="project-carousel-dots" role="tablist" aria-label={`${title} screenshots`}>
                    {
                      images.map((_, dotIndex) => (
                        <button
                          type="button"
                          class={`project-carousel-dot ${dotIndex === 0 ? "is-active" : ""}`}
                          role="tab"
                          aria-label={`Show screenshot ${dotIndex + 1}`}
                          aria-selected={dotIndex === 0 ? "true" : "false"}
                          data-dot-index={dotIndex}
                        />
                      ))
                    }
                  </div>
                </>
              )
            }
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-row flex-wrap mb-2 gap-2">
              {
                tags.map((tag) => (
                  <li>
                    <span
                      class={`rounded-full text-xs py-1 px-2 ${TAG_STYLES[tag] ?? "bg-gray-700 text-white"}`}
                    >
                      {tag}
                    </span>
                  </li>
                ))
              }
            </ul>

            <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {
                github && (
                  <LinkButton href={github}>
                    <GitHub class="size-6" />
                    Code
                  </LinkButton>
                )
              }
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>

<div
  id="project-lightbox"
  class="project-lightbox hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Project image preview"
  aria-hidden="true"
>
  <button type="button" class="project-lightbox-backdrop" aria-label="Close image preview"></button>
  <div class="project-lightbox-content">
    <button type="button" class="project-lightbox-close" aria-label="Close image preview">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6L6 18"></path>
        <path d="M6 6l12 12"></path>
      </svg>
    </button>
    <button type="button" class="project-lightbox-nav project-lightbox-nav--prev" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <img id="project-lightbox-image" class="project-lightbox-image" src="" alt="" />
    <button type="button" class="project-lightbox-nav project-lightbox-nav--next" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
  </div>
</div>

<script define:vars={{ projects: PROJECTS }}>
  // @ts-nocheck
  const initProjectCarousels = () => {
    document.querySelectorAll(".project-carousel").forEach((carousel) => {
      if (carousel.dataset.initialized === "true") return
      carousel.dataset.initialized = "true"

      const slides = carousel.querySelectorAll(".project-carousel-slide")
      const dots = carousel.querySelectorAll(".project-carousel-dot")
      const prevBtn = carousel.querySelector(".project-carousel-btn--prev")
      const nextBtn = carousel.querySelector(".project-carousel-btn--next")
      if (slides.length <= 1) return

      let activeIndex = 0

      const goTo = (index) => {
        activeIndex = (index + slides.length) % slides.length

        slides.forEach((slide, i) => {
          slide.classList.toggle("is-active", i === activeIndex)
        })

        dots.forEach((dot, i) => {
          dot.classList.toggle("is-active", i === activeIndex)
          dot.setAttribute("aria-selected", i === activeIndex ? "true" : "false")
        })
      }

      prevBtn?.addEventListener("click", (event) => {
        event.stopPropagation()
        goTo(activeIndex - 1)
      })
      nextBtn?.addEventListener("click", (event) => {
        event.stopPropagation()
        goTo(activeIndex + 1)
      })

      dots.forEach((dot) => {
        dot.addEventListener("click", (event) => {
          event.stopPropagation()
          const index = Number(dot.getAttribute("data-dot-index"))
          if (!Number.isNaN(index)) goTo(index)
        })
      })
    })
  }

  let lightboxProjectIndex = 0
  let lightboxImageIndex = 0

  const getLightboxElements = () => ({
    lightbox: document.getElementById("project-lightbox"),
    image: document.getElementById("project-lightbox-image"),
    prevBtn: document.querySelector(".project-lightbox-nav--prev"),
    nextBtn: document.querySelector(".project-lightbox-nav--next"),
  })

  const updateLightboxImage = () => {
    const { lightbox, image, prevBtn, nextBtn } = getLightboxElements()
    if (!lightbox || !image) return

    const project = projects[lightboxProjectIndex]
    const images = project?.images ?? []
    const src = images[lightboxImageIndex]
    const hasMultiple = images.length > 1

    image.src = src
    image.alt = `${project.title} screenshot ${lightboxImageIndex + 1}`

    if (prevBtn) prevBtn.style.display = hasMultiple ? "flex" : "none"
    if (nextBtn) nextBtn.style.display = hasMultiple ? "flex" : "none"
  }

  const openLightbox = (projectIndex, imageIndex) => {
    const { lightbox } = getLightboxElements()
    if (!lightbox) return

    lightboxProjectIndex = projectIndex
    lightboxImageIndex = imageIndex
    updateLightboxImage()

    lightbox.classList.remove("hidden")
    lightbox.setAttribute("aria-hidden", "false")
    document.body.style.overflow = "hidden"
  }

  const closeLightbox = () => {
    const { lightbox, image } = getLightboxElements()
    if (!lightbox) return

    lightbox.classList.add("hidden")
    lightbox.setAttribute("aria-hidden", "true")
    document.body.style.overflow = ""

    if (image) {
      image.src = ""
      image.alt = ""
    }
  }

  const initProjectLightbox = () => {
    const { lightbox, prevBtn, nextBtn } = getLightboxElements()
    if (!lightbox) return

    document.querySelectorAll(".project-image-trigger").forEach((trigger) => {
      if (trigger.dataset.lightboxBound === "true") return
      trigger.dataset.lightboxBound = "true"

      trigger.addEventListener("click", () => {
        const projectIndex = Number(trigger.getAttribute("data-project-index"))
        const imageIndex = Number(trigger.getAttribute("data-image-index"))
        if (Number.isNaN(projectIndex) || Number.isNaN(imageIndex)) return
        openLightbox(projectIndex, imageIndex)
      })
    })

    if (lightbox.dataset.controlsBound === "true") return
    lightbox.dataset.controlsBound = "true"

    lightbox.querySelector(".project-lightbox-backdrop")?.addEventListener("click", closeLightbox)
    lightbox.querySelector(".project-lightbox-close")?.addEventListener("click", closeLightbox)

    prevBtn?.addEventListener("click", () => {
      const images = projects[lightboxProjectIndex]?.images ?? []
      lightboxImageIndex = (lightboxImageIndex - 1 + images.length) % images.length
      updateLightboxImage()
    })

    nextBtn?.addEventListener("click", () => {
      const images = projects[lightboxProjectIndex]?.images ?? []
      lightboxImageIndex = (lightboxImageIndex + 1) % images.length
      updateLightboxImage()
    })

    document.addEventListener("keydown", (event) => {
      if (lightbox.classList.contains("hidden")) return

      if (event.key === "Escape") closeLightbox()
      if (event.key === "ArrowLeft") prevBtn?.click()
      if (event.key === "ArrowRight") nextBtn?.click()
    })
  }

  initProjectCarousels()
  initProjectLightbox()
  document.addEventListener("astro:page-load", () => {
    initProjectCarousels()
    initProjectLightbox()
  })
</script>

<style>
  .project-carousel-track {
    position: relative;
    overflow: hidden;
  }

  .project-carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.45s ease;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    width: 100%;
    height: 100%;
  }

  .project-carousel-slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .project-carousel-btn {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: #111;
    background: rgba(255, 255, 255, 0.92);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transform: translateY(-50%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .project-carousel-btn:hover {
    transform: translateY(-50%) scale(1.06);
    background: #fff;
  }

  .project-carousel-btn--prev {
    left: 0.75rem;
  }

  .project-carousel-btn--next {
    right: 0.75rem;
  }

  :global(.dark) .project-carousel-btn {
    color: #f4f4f5;
    background: rgba(39, 39, 42, 0.92);
  }

  :global(.dark) .project-carousel-btn:hover {
    background: #27272a;
  }

  .project-carousel-dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    z-index: 2;
    display: flex;
    gap: 0.4rem;
    transform: translateX(-50%);
  }

  .project-carousel-dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    background: rgba(255, 255, 255, 0.55);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .project-carousel-dot.is-active {
    background: #e98300;
    transform: scale(1.15);
  }

  .project-lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .project-lightbox.hidden {
    display: none;
  }

  .project-lightbox-backdrop {
    position: absolute;
    inset: 0;
    border: none;
    background: rgba(0, 0, 0, 0.85);
    cursor: pointer;
  }

  .project-lightbox-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(92vw, 72rem);
    max-height: 90vh;
  }

  .project-lightbox-image {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.75rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
  }

  .project-lightbox-close {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.65);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .project-lightbox-close:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: scale(1.05);
  }

  .project-lightbox-nav {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: #111;
    background: rgba(255, 255, 255, 0.92);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transform: translateY(-50%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .project-lightbox-nav:hover {
    transform: translateY(-50%) scale(1.06);
    background: #fff;
  }

  .project-lightbox-nav--prev {
    left: -1rem;
  }

  .project-lightbox-nav--next {
    right: -1rem;
  }

  @media (max-width: 640px) {
    .project-lightbox-nav--prev {
      left: 0.25rem;
    }

    .project-lightbox-nav--next {
      right: 0.25rem;
    }

    .project-lightbox-close {
      top: 0.25rem;
      right: 0.25rem;
    }
  }
</style>
